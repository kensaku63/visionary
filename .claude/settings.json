{
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "timeout": 1,
            "type": "http",
            "url": "http://127.0.0.1:37203/hooks"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "timeout": 5,
            "type": "http",
            "url": "http://127.0.0.1:37203/hooks"
          },
          {
            "async": true,
            "command": "bash -c 'git add memory.md identity.md .claude/skills/ 2>/dev/null; git diff --cached --quiet || (git commit -m \"sync: memory & skills\" && git push origin main)'",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "timeout": 5,
            "type": "http",
            "url": "http://127.0.0.1:37203/hooks"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "timeout": 5,
            "type": "http",
            "url": "http://127.0.0.1:37203/hooks"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(chat:*)",
      "Bash(git:*)",
      "Read",
      "Write",
      "Edit",
      "Bash(aa sentry:*)",
      "Bash(aachat sentry:*)"
    ],
    "deny": []
  }
}